{
  "name": "@gym-equipment-ai/api",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "build:fc": "esbuild src/adapters/aliyunFcRecognition.ts --bundle --platform=node --format=cjs --target=node20 --outfile=../../dist/aliyun-fc/index.js",
    "dev": "tsx watch src/server.ts",
    "start": "node --import tsx src/server.ts",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@gym-equipment-ai/shared": "workspace:*",
    "fastify": "^5.3.2",
    "openai": "^5.7.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
