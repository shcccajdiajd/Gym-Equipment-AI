.page {
  min-height: 100vh;
  padding: 48rpx 32rpx;
  background:
    radial-gradient(circle at top left, rgba(31, 111, 80, 0.14), transparent 45%),
    linear-gradient(180deg, #f7f5ef 0%, #efe9db 100%);
}

.hero {
  margin-top: 96rpx;
  margin-bottom: 72rpx;
}

.eyebrow {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(31, 111, 80, 0.12);
  color: #1f6f50;
  font-size: 22rpx;
  letter-spacing: 2rpx;
}

.title {
  display: block;
  margin-top: 28rpx;
  font-size: 56rpx;
  font-weight: 700;
  line-height: 1.22;
}

.subtitle {
  display: block;
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #4d5f53;
  line-height: 1.6;
}

.action {
  margin-top: 24rpx;
}

.ghost-link {
  margin-top: 32rpx;
  color: #1f6f50;
  text-align: center;
  font-size: 28rpx;
}

.demo-panel {
  margin-top: 64rpx;
  padding: 28rpx 24rpx 32rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.78);
  box-shadow: 0 10rpx 36rpx rgba(31, 42, 31, 0.08);
}

.demo-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2a1f;
}

.demo-copy {
  display: block;
  margin-top: 12rpx;
  color: #4d5f53;
  line-height: 1.6;
  font-size: 26rpx;
}
