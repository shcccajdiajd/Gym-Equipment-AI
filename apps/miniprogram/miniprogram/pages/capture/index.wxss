.camera-page {
  min-height: 100vh;
  padding: 24rpx;
}

.camera {
  width: 100%;
  height: 920rpx;
  border-radius: 24rpx;
  overflow: hidden;
  background: #d7ddd8;
}

.hint-card {
  margin-top: 24rpx;
  padding: 28rpx 24rpx;
  background: #ffffff;
  border-radius: 20rpx;
  color: #4d5f53;
}

.hint-title {
  display: block;
  margin-bottom: 12rpx;
  color: #1f2a1f;
  font-size: 28rpx;
  font-weight: 700;
}

.hint-text {
  display: block;
  line-height: 1.6;
  font-size: 26rpx;
}

.capture-button {
  margin-top: 24rpx;
}
